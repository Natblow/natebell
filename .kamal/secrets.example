# Copy to .kamal/secrets and fill in your registry credentials.
# .kamal/secrets is git-ignored — never commit real values.
#
# Option A — gh CLI token (must include write:packages):
#   gh auth refresh -h github.com -s write:packages,read:packages,delete:packages
#   KAMAL_REGISTRY_PASSWORD=$(gh auth token)
#
# Option B — classic GitHub PAT with write:packages + read:packages:
#   KAMAL_REGISTRY_PASSWORD=ghp_your_token

KAMAL_REGISTRY_PASSWORD=$(gh auth token)
